{
  "name": "yujimin.dev",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run cf-typegen && npm run db:generate && velite build && next dev",
    "clean": "rimraf .next .open-next .velite src/velite-types.d.ts",
    "build:content": "velite build",
    "build": "next build --webpack",
    "build:next": "opennextjs-cloudflare build",
    "build:copy-assets": "cpy .velite/public/static/** .open-next/assets/static",
    "build:deploy": "npm run clean && npm run build:content && npm run build:next && npm run build:copy-assets",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prepare": "husky",
    "wrangler": "wrangler",
    "dev:cf": "npm run build:deploy && wrangler dev",
    "preview": "npm run build:deploy && wrangler dev",
    "deploy": "npm run build:deploy && wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "db:generate": "drizzle-kit generate --config=./drizzle.local.config.ts",
    "db:migrate:local": "wrangler d1 migrations apply yujimin-dev-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply yujimin-dev-db --remote",
    "db:studio": "drizzle-kit studio --config=./drizzle.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "script:test-resume": "bash scripts/test-resume-cache.sh",
    "script:test-local": "bash scripts/test-local.sh",
    "script:seed-cache": "bash scripts/seed-resume-cache.sh",
    "script:verify-deploy": "bash scripts/verify-deployment.sh"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "eslint --fix",
    "*.{js,jsx,ts,tsx,css,md}": "prettier --write"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@yuji-min/google-docs-parser": "^1.0.3",
    "drizzle-orm": "^0.44.6",
    "googleapis": "^164.1.0",
    "html-react-parser": "^5.2.17",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.65.0",
    "react-infinite-scroll-hook": "^6.0.1",
    "react-intersection-observer": "^9.16.0",
    "rehype-prism-plus": "^2.0.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.16.5",
    "@playwright/test": "^1.58.0",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "babel-plugin-react-compiler": "^1.0.0",
    "better-sqlite3": "^12.4.1",
    "cpy-cli": "^6.0.0",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.5",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.0",
    "open-next": "^3.1.3",
    "prettier": "^3.6.2",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "velite": "^0.3.0",
    "vitest": "^4.0.18",
    "wrangler": "^4.43.0"
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
